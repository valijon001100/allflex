# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_EXTRA_ALLOWED_HOSTS=allflex.doccmed.uz,www.allflex.doccmed.uz,allflex-ota0.onrender.com

# Render production:
# DJANGO_ALLOWED_HOSTS=allflex-ota0.onrender.com,allflex.doccmed.uz,www.allflex.doccmed.uz
# DJANGO_CSRF_TRUSTED_ORIGINS=https://allflex-ota0.onrender.com,https://allflex.doccmed.uz,https://www.allflex.doccmed.uz

# Click (https://my.click.uz — kabinetdan oling)
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Payme (https://merchant.paycom.uz — kabinetdan oling)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# Click callback URL (Click kabinetida ko'rsating):
# https://yourdomain.com/payment/click/
# Payme callback URL:
# https://yourdomain.com/payment/payme/

# Telegram video kanal (bot @BotFather dan, bot kanalga admin bo'lishi kerak)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=-1003920859525
# Botga video yuboradigan adminlar (Telegram user ID, vergul bilan)
TELEGRAM_ADMIN_USER_IDS=8630643858
TELEGRAM_WEBHOOK_SECRET=random-secret-string
TELEGRAM_WEBHOOK_URL=https://allflex.doccmed.uz/telegram/webhook/
SITE_BASE_URL=https://allflex.doccmed.uz
TELEGRAM_DELETE_LOCAL_AFTER_UPLOAD=True

# GB videolar (2GB gacha) — Local Bot API server kerak:
# TELEGRAM_API_BASE=http://127.0.0.1:8081
# TELEGRAM_LOCAL_MEDIA_ROOT=/media
# TELEGRAM_MAX_UPLOAD_BYTES=2147483648
# TELEGRAM_UPLOAD_TIMEOUT=7200
